{
  "private": true,
  "name": "root",
  "license": "UNLICENSED",
  "scripts": {
    "update": "yarn upgrade-interactive",
    "build": "yarn build:product_srv",
    "build:product_srv": "yarn workspaces foreach --from '@service/product' -R -t run build",
    "dev:product_srv": "yarn workspace @service/product start:dev",
    "build:outbox": "yarn workspace @sellgar/outbox build"
  },
  "workspaces": [
    "service",
    "library/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.10.3"
}
